# Copy to .env and fill in. The real .env is gitignored; keep all secrets there.
# Loaded by shared_lib.config.load_env() and by VS Code (python.envFile).

# Import path for running scripts from the repo root
PYTHONPATH=projects;projects/shared_lib

# YouTube Data API v3 key (projects/youtube)
YOUTUBE_API_KEY=

# Google Knowledge Graph Search API key (projects/google); optional,
# KG lookups by search text are skipped when empty
GOOGLE_KG_API_KEY=

# Local Firebird credentials, used for all per-project tracking databases.
# Project *.json configs only need DB_HOST; DB_USER/DB_PASSWORD in a JSON
# still take precedence if present.
WD_DB_USER=
WD_DB_PASSWORD=

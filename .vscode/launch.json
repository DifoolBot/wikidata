{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true
        },
        {
            "name": "clean_youtube: dry-run one QID",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/projects/clean_youtube/youtube_metadata.py",
            "args": ["--qid", "${input:qid}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": false
        },
        {
            "name": "clean_google: fetch-items",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/projects/clean_google/clean_google_links.py",
            "args": ["--fetch-items"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": false
        },
        {
            "name": "clean_youtube: custom args",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/projects/clean_youtube/youtube_metadata.py",
            "args": "${command:pickArgs}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": false
        }
    ],
    "inputs": [
        {
            "id": "qid",
            "type": "promptString",
            "description": "QID to process (dry run, bypasses the done-check)",
            "default": "Q98940354"
        }
    ]
}